rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function verified() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function role() {
      return signedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : 'user';
    }

    function isSuperAdmin() {
      return role() == 'superadmin';
    }

    function isModeratorForCollege(collegeId) {
      return isSuperAdmin() ||
        role() == 'admin' ||
        (role() == 'moderator' && request.auth.token.collegeId == collegeId);
    }

    function safeFile() {
      return request.resource != null
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*');
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if verified() && request.auth.uid == userId;
      allow write: if verified() && request.auth.uid == userId && safeFile();
    }

    match /resources/{resourceId}/{fileName} {
      function resourceDoc() {
        return firestore.get(/databases/(default)/documents/hub_resources/$(resourceId));
      }

      allow read: if verified()
        && resourceDoc().data.deletedAt == null
        && (resourceDoc().data.status == 'approved'
          || resourceDoc().data.uploadedBy == request.auth.uid
          || isModeratorForCollege(resourceDoc().data.collegeId));
      allow write: if verified() && safeFile()
        && (!firestore.exists(/databases/(default)/documents/hub_resources/$(resourceId))
          || resourceDoc().data.uploadedBy == request.auth.uid
          || isModeratorForCollege(resourceDoc().data.collegeId));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
