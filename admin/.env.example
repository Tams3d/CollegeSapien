# CodeSapiens API (Firebase Cloud Functions)
NUXT_PUBLIC_API_BASE_URL=https://api-awfkwymcxa-el.a.run.app/api/v1

# Firebase Client SDK
NUXT_PUBLIC_FIREBASE_API_KEY=AIza...
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=<project-id>.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=<project-id>
NUXT_PUBLIC_FIREBASE_APP_ID=1:...:web:...

# App Check debug token — register this UUID in Firebase Console → App Check → Debug Tokens
NUXT_PUBLIC_APP_CHECK_DEBUG_TOKEN=<uuid-v4>
